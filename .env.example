# ===========================================
# SUPABASE (required)
# ===========================================
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# STRIPE (required for payments)
# ===========================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxx

# Get from: https://dashboard.stripe.com/webhooks
# Create endpoint and select: checkout.session.completed, account.updated
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ===========================================
# CLOUDFLARE R2 (required for album file storage)
# ===========================================
# Get from: https://dash.cloudflare.com → R2 → Manage R2 tokens
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key
CLOUDFLARE_R2_BUCKET=music-marketplace

# Public URL for serving uploaded files (configured in R2 bucket settings)
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.your-account.r2.dev

# ===========================================
# APPLICATION
# ===========================================
# Base URL for redirect URLs after checkout (your deployed domain)
BASE_URL=https://fuzzymoss.zo.space
